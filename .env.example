# ==============================================================================
# SMART VENDING MACHINE - CENTRALIZED ENVIRONMENT CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
DB_HOST=db
DB_USER=root
DB_PASSWORD=root
DB_NAME=vending
# --- Optional (has defaults in server/app/db_config/db.py) ---
DB_POOL_NAME=app_pool          # ชื่อ connection pool
DB_POOL_SIZE=10                # จำนวน connection ใน pool (default 10)
DB_MAX_RETRIES=30              # รอ MySQL ตอน startup กี่ครั้ง
DB_RETRY_DELAY=1               # ห่างกี่วินาทีต่อครั้ง

# ------------------------------------------------------------------------------
# Omise — Payment Gateway
# ------------------------------------------------------------------------------
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxx
# Production: set and verify Omise webhook HMAC (buy.py skips verify if unset — dev only)
# OMISE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Machine UI — Frontend (build-time variables)
# Local dev (browser + Docker on same PC): keep localhost below.
# Pi/LAN kiosk (browser on another device): set NEXT_PUBLIC_API_URL and SOCKET to (http://<host-LAN-IP>:8000), add that origin to CORS_ORIGINS, then rebuild machine-ui.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000 # (http://<host-LAN-IP>:8000)
NEXT_PUBLIC_MACHINE_CODE=MP1-001 # (machine_code from Admin)
NEXT_PUBLIC_AGENT_BASE_URL=http://localhost:5000 # (http://<Agent-IP>:5000)
NEXT_PUBLIC_SERVER_SOCKET_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# Machine UI Socket secret (required; must match)
# ------------------------------------------------------------------------------
KIOSK_SOCKET_SECRET=dev-kiosk-secret-change-in-production
NEXT_PUBLIC_KIOSK_SOCKET_SECRET=dev-kiosk-secret-change-in-production

# ------------------------------------------------------------------------------
# Admin UI
# ------------------------------------------------------------------------------
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8000 # (http://<host-LAN-IP>:8000)

# ------------------------------------------------------------------------------
# Server — Dispatch hardware jobs and Socket.IO
# ------------------------------------------------------------------------------
AGENT_BASE_URL=http://localhost:5000
AGENT_URL=http://localhost:5000/dispense
AGENT_PORT=5000
SOCKETIO_ENABLED=1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8081,http://localhost:8000 # (เพิ่ม http://<host-LAN-IP>:3000, http://<host-LAN-IP>:3001, http://<host-LAN-IP>:3002, http://<host-LAN-IP>:8081, http://<host-LAN-IP>:8000)
# DISPATCH_MODE=socket

# ------------------------------------------------------------------------------
# MEMBER OTP / JWT (web-ui login)
# ------------------------------------------------------------------------------
# Twilio SMS (leave empty to log OTP to server console instead)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

JWT_SECRET=dev-change-me-in-production
JWT_EXPIRES_HOURS=168
OTP_TTL_SECONDS=300
# Server-side dev only: 1 = accept any 6-digit OTP without checking DB (never use in production)
AUTH_DEV_BYPASS=0
ALLOW_MOCK_PAY=1

# ADMIN_SOCKET_SECRET: optional. When set, admin-ui Socket.IO must send auth.admin_token matching this value.
# When empty, dev mode accepts auth JSON { "role": "admin" } only (see server/app/realtime/socketio_gateway.py).
ADMIN_SOCKET_SECRET=

# ------------------------------------------------------------------------------
# Raspberry Pi agent (Docker `client` service reads MACHINE_CODE / MACHINE_TOKEN from root .env)
# ------------------------------------------------------------------------------
MACHINE_ID=MP1-001
MACHINE_CODE=MP1-001
# Docker client / dev: dev-machine-token (matches seed init.sql). Pi: Admin secret or same dev token.
MACHINE_TOKEN=dev-machine-token
SERVER_SOCKET_URL=http://server:8000
SERVER_URL=http://server:8000
AGENT_DB_PATH=/data/agent.db
SENSOR_MODE=mock

# web-ui build: member app fulfillment mode (immediate | pickup)
# NEXT_PUBLIC_FULFILLMENT_MODE=immediate
# Published ports: machine-ui 3000, admin-ui 3001, web-ui 3002, server 8000, swagger-ui 8081 (host), db 3307, agent 5000
# docker-compose.yml also sets DOCKER_URL_* env vars on server/client for startup URL banners (optional locally).

# ------------------------------------------------------------------------------
# Raspberry Pi agent — GPIO/NFC
# ------------------------------------------------------------------------------
# Raspberry Pi agent — GPIO/NFC (refer to client/agent/.env.example)
