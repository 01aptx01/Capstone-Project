# ==============================================================================
# SMART VENDING MACHINE - CENTRALIZED ENVIRONMENT CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
DB_HOST=db
DB_USER=root
DB_PASSWORD=root
DB_NAME=vending
# --- Optional (has defaults in server/app/db_config/db.py) ---
DB_POOL_NAME=app_pool
DB_POOL_SIZE=10
DB_MAX_RETRIES=30
DB_RETRY_DELAY=1

# ------------------------------------------------------------------------------
# Omise — Payment Gateway
# ------------------------------------------------------------------------------
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxx
# Production: set and verify Omise webhook HMAC (buy.py skips verify if unset — dev only)
# OMISE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Machine UI — Frontend (build-time variables)
# Local dev: localhost below. LAN kiosk: use http://<host-LAN-IP>:8000 and rebuild machine-ui.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MACHINE_CODE=MP1-001
NEXT_PUBLIC_AGENT_BASE_URL=http://localhost:5000
# NEXT_PUBLIC_SERVER_SOCKET_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# Machine UI Socket secret (required; must match)
# ------------------------------------------------------------------------------
KIOSK_SOCKET_SECRET=dev-kiosk-secret-change-in-production
NEXT_PUBLIC_KIOSK_SOCKET_SECRET=dev-kiosk-secret-change-in-production

# ------------------------------------------------------------------------------
# Admin UI
# ------------------------------------------------------------------------------
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# Server — Socket.IO and agent health
# ------------------------------------------------------------------------------
AGENT_BASE_URL=http://localhost:5000
SOCKETIO_ENABLED=1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8081,http://localhost:8000
# ADMIN_SOCKET_SECRET: optional. When set, admin-ui Socket.IO must send auth.admin_token matching this value.

# ------------------------------------------------------------------------------
# Member OTP / JWT (web-ui login)
# OTP is logged to the server console (ConsoleSmsService). Never use AUTH_DEV_BYPASS in production.
# ------------------------------------------------------------------------------
JWT_SECRET=dev-change-me-in-production
JWT_EXPIRES_HOURS=168
OTP_TTL_SECONDS=300
# OTP_HASH_SALT=modpao-otp
AUTH_DEV_BYPASS=0
ALLOW_MOCK_PAY=1

# ------------------------------------------------------------------------------
# Raspberry Pi agent (Docker `client` reads MACHINE_CODE / MACHINE_TOKEN from root .env)
# ------------------------------------------------------------------------------
MACHINE_CODE=MP1-001
MACHINE_TOKEN=dev-machine-token
SERVER_SOCKET_URL=http://server:8000
AGENT_DB_PATH=/data/agent.db
SENSOR_MODE=mock

# Published ports: machine-ui 3000, admin-ui 3001, web-ui 3002, server 8000, swagger-ui 8081, db 3307, agent 5000
# GPIO/NFC on real Pi: see client/agent/.env.example


