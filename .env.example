# ==============================================================================
# SMART VENDING MACHINE - CENTRALIZED ENVIRONMENT CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
DB_HOST=db
DB_USER=root
DB_PASSWORD=root
DB_NAME=vending
DB_POOL_NAME=app_pool
DB_POOL_SIZE=5
DB_MAX_RETRIES=30
DB_RETRY_DELAY=1
# DB_PORT=3306

# ------------------------------------------------------------------------------
# OMISE PAYMENT GATEWAY CONFIGURATION
# ------------------------------------------------------------------------------
# PUBLIC KEY
NEXT_PUBLIC_OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxx
# SECRET KEY
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# BACKEND API CONFIGURATION
# ------------------------------------------------------------------------------
# The URL where the Flask server is running
NEXT_PUBLIC_API_URL=http://localhost:8000
# Admin dashboard (Next.js): browser must reach Flask from the host (not http://server:8000)
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8000
# Redirect URI for 3-D Secure or other payment redirects
RETURN_URI=http://localhost:3000/payment-result

# ------------------------------------------------------------------------------
# HARDWARE AGENT CONFIGURATION (Raspberry Pi)
# ------------------------------------------------------------------------------
# The URL where the hardware agent (Python) is listening for dispense commands
# Default port is 5000
AGENT_URL=http://localhost:5000/dispense
# Agent Port (used by the agent itself)
AGENT_PORT=5000
# Unique identifier for this specific machine
MACHINE_ID=MP1-001

# ------------------------------------------------------------------------------
# ENTERPRISE FLEET SOCKET.IO AUTH (RECOMMENDED)
# ------------------------------------------------------------------------------
# FLEET_SECRET: set on the SERVER only. All machine keys are derived from it.
FLEET_SECRET=change-me-to-a-long-random-string

# MACHINE_CODE: canonical ID for this machine (used as Socket.IO room name).
# Use machine_code everywhere; MACHINE_ID is kept for legacy compatibility.
MACHINE_CODE=MP1-001
MACHINE_ID=MP1-001

# MACHINE_SECRET_KEY: set on the AGENT (Pi5) only.
# Must be the hex output of:  HMAC-SHA256(FLEET_SECRET, MACHINE_CODE)
# Generate it with Python:
#   python3 -c "import hmac, hashlib; \
#     print(hmac.new(b'<FLEET_SECRET>', b'<MACHINE_CODE>', hashlib.sha256).hexdigest())"
MACHINE_SECRET_KEY=

# SERVER_SOCKET_URL: where the agent connects for Socket.IO (agent .env)
SERVER_SOCKET_URL=http://server:8000
SERVER_URL=http://server:8000

# NEXT_PUBLIC_SERVER_SOCKET_URL: where the browser machine-ui connects for Socket.IO
NEXT_PUBLIC_SERVER_SOCKET_URL=http://localhost:8000

# NEXT_PUBLIC_MACHINE_CODE: machine code used by the browser to join the right room
NEXT_PUBLIC_MACHINE_CODE=MP1-001

# ------------------------------------------------------------------------------
# DISPATCH MODE
# ------------------------------------------------------------------------------
# "socket" (default): Server dispatches job.start via Socket.IO room
# "http": Server sends HTTP POST to AGENT_URL (legacy, not recommended)
DISPATCH_MODE=socket
