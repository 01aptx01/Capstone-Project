# ==============================================================================
# SMART VENDING MACHINE - CENTRALIZED ENVIRONMENT CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
DB_HOST=db
DB_USER=root
DB_PASSWORD=root
DB_NAME=vending
DB_POOL_NAME=app_pool
DB_POOL_SIZE=5
DB_MAX_RETRIES=30
DB_RETRY_DELAY=1
# DB_PORT=3306

# ------------------------------------------------------------------------------
# OMISE PAYMENT GATEWAY CONFIGURATION
# ------------------------------------------------------------------------------
# PUBLIC KEY
NEXT_PUBLIC_OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxx
# SECRET KEY
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# BACKEND API CONFIGURATION
# ------------------------------------------------------------------------------
# The URL where the Flask server is running (machine-ui, shared public API base).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Admin dashboard (Next.js web/admin-ui): fetch layer (lib/admin-api.ts). Keep the same reachable URL as NEXT_PUBLIC_API_URL unless you split origins.
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8000
# Admin-ui Axios (web/admin-ui/lib/axios.ts) uses NEXT_PUBLIC_API_URL first, then NEXT_PUBLIC_ADMIN_API_URL, then http://localhost:8000.
# Redirect URI for 3-D Secure or other payment redirects
RETURN_URI=http://localhost:3000/payment-result

# ------------------------------------------------------------------------------
# HARDWARE AGENT CONFIGURATION (Raspberry Pi / docker-compose `client`)
# ------------------------------------------------------------------------------
# The URL where the hardware agent (Python) is listening for dispense commands
# Default port is 5000
AGENT_URL=http://localhost:5000/dispense
# Agent Port (used by the agent itself)
AGENT_PORT=5000

# Identity: must match `machines.machine_code` in the DB (prefer MACHINE_ID).
MACHINE_ID=MP1-001
# Optional legacy alias read by the agent if MACHINE_ID is unset
MACHINE_CODE=MP1-001

# Socket.IO auth (agent → server): one-time plaintext from Admin → Create machine.
# docker-compose passes this into the `client` service as MACHINE_TOKEN automatically.
MACHINE_TOKEN=

# SERVER_SOCKET_URL: where the agent connects for Socket.IO (use service name in Docker)
SERVER_SOCKET_URL=http://server:8000
SERVER_URL=http://server:8000

# NEXT_PUBLIC_SERVER_SOCKET_URL: where the browser machine-ui connects for Socket.IO
NEXT_PUBLIC_SERVER_SOCKET_URL=http://localhost:8000

# NEXT_PUBLIC_MACHINE_CODE: machine code used by the browser to join the right room
NEXT_PUBLIC_MACHINE_CODE=MP1-001

# ADMIN_SOCKET_SECRET: optional. When set, admin-ui Socket.IO must send auth.admin_token matching this value.
# When empty, dev mode accepts auth JSON { "role": "admin" } only (see server/app/realtime/socketio_gateway.py).
ADMIN_SOCKET_SECRET=

# ------------------------------------------------------------------------------
# DOCKER COMPOSE — FRONTENDS (optional build args)
# ------------------------------------------------------------------------------
# machine-ui build: NEXT_PUBLIC_MACHINE_CODE is baked in at image build (change → rebuild machine-ui)
NEXT_PUBLIC_AGENT_BASE_URL=
# admin-ui build: URL the browser uses to reach Flask (host machine, not service name)
# NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8000
# Published ports: machine-ui 3000, admin-ui 3001, server 8000, swagger-ui 8081 (host), db 3307, agent 5000
# docker-compose.yml also sets DOCKER_URL_* env vars on server/client for startup URL banners (optional locally).

# ------------------------------------------------------------------------------
# DISPATCH MODE
# ------------------------------------------------------------------------------
# "socket" (default): Server dispatches job.start via Socket.IO room
# "http": Server sends HTTP POST to AGENT_URL (legacy, not recommended)
DISPATCH_MODE=socket
