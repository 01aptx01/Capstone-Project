# ==============================================================================
# SMART VENDING MACHINE - CENTRALIZED ENVIRONMENT CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
DB_HOST=db
DB_USER=root
DB_PASSWORD=root
DB_NAME=vending
# --- Optional (has defaults in server/app/db_config/db.py) ---
DB_POOL_NAME=app_pool          # ชื่อ connection pool
DB_POOL_SIZE=10                # จำนวน connection ใน pool (default 10)
DB_MAX_RETRIES=30              # รอ MySQL ตอน startup กี่ครั้ง
DB_RETRY_DELAY=1               # ห่างกี่วินาทีต่อครั้ง

# ------------------------------------------------------------------------------
# Omise — Payment Gateway
# ------------------------------------------------------------------------------
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# Machine UI — Frontend (build-time variables)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MACHINE_CODE=MP1-001
NEXT_PUBLIC_AGENT_BASE_URL=http://localhost:5000
# --- Optional (defaults to NEXT_PUBLIC_API_URL if unset) ---
# NEXT_PUBLIC_SERVER_SOCKET_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# Machine UI Socket secret (required; must match)
# ------------------------------------------------------------------------------
KIOSK_SOCKET_SECRET=dev-kiosk-secret-change-in-production
NEXT_PUBLIC_KIOSK_SOCKET_SECRET=dev-kiosk-secret-change-in-production

# ------------------------------------------------------------------------------
# Admin UI
# ------------------------------------------------------------------------------
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# Server — Dispatch hardware jobs and Socket.IO
# ------------------------------------------------------------------------------
AGENT_BASE_URL=http://localhost:5000
SOCKETIO_ENABLED=1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081
# (optional = dev mode only; leave empty for production)
ADMIN_SOCKET_SECRET=

# ------------------------------------------------------------------------------
# Raspberry Pi agent
# ------------------------------------------------------------------------------
MACHINE_CODE=MP1-001
MACHINE_TOKEN=
SERVER_SOCKET_URL=http://server:8000
AGENT_DB_PATH=/data/agent.db
SENSOR_MODE=mock

# ------------------------------------------------------------------------------
# Raspberry Pi agent — GPIO/NFC
# ------------------------------------------------------------------------------
# Raspberry Pi agent — GPIO/NFC (refer to client/agent/.env.example)