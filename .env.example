# ==============================================================================
# SMART VENDING MACHINE - CENTRALIZED ENVIRONMENT CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION (Backend Only)
# ------------------------------------------------------------------------------
DB_HOST=localhost            # Use 'db' if running via Docker
DB_USER=root
DB_PASSWORD=root_password
DB_NAME=vending
DB_PORT=3306                 # Default MySQL port

# ------------------------------------------------------------------------------
# 2. OMISE PAYMENT GATEWAY CONFIGURATION
# ------------------------------------------------------------------------------
# PUBLIC KEY (Safe for Frontend - Prefixed with NEXT_PUBLIC_ for Next.js)
NEXT_PUBLIC_OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxx

# SECRET KEY (SERVER-SIDE ONLY - NEVER EXPOSE TO FRONTEND)
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# 3. BACKEND API CONFIGURATION (Flask)
# ------------------------------------------------------------------------------
# The URL where the Flask server is running
NEXT_PUBLIC_API_URL=http://localhost:8000

# Redirect URI for 3-D Secure or other payment redirects
RETURN_URI=http://localhost:3000/payment-result

# ------------------------------------------------------------------------------
# 4. HARDWARE AGENT CONFIGURATION (Raspberry Pi)
# ------------------------------------------------------------------------------
# The URL where the hardware agent (Python) is listening for dispense commands
# Default port is 5000
AGENT_URL=http://localhost:5000/dispense

# Agent Port (used by the agent itself)
AGENT_PORT=5000

# Unique identifier for this specific machine
MACHINE_ID=MP1-001
