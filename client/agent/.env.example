# ==============================================================================
# Raspberry Pi Agent Environment
# ==============================================================================
# How to run on Raspberry Pi:
# 1) cd /home/klongyaa4/Desktop/Capstone-Project/client/agent
# 2) python3 -m venv .venv
# 3) source .venv/bin/activate
# 4) pip install -r requirements.txt
# 5) export $(grep -v '^#' .env | xargs)   # if you copy this file to .env
# 6) python agent.py
#
# Optional standalone hardware controller:
# python machine.py
# ==============================================================================

# Machine identity
MACHINE_CODE=MP1-001
MACHINE_ID=MP1-001

# UI to show on the Raspberry Pi touch screen
MACHINE_UI_URL=http://192.168.1.44:3000

AGENT_DB_PATH=/home/klongyaa4/Desktop/Capstone-Project/client/agent/agent.db

# GPIO pins
# RGB LED 1: 14,15,18
# RGB LED 2: 23,24,25
# RGB LED 3: 8,7,12
# RGB LED 4: 16,20,21
RGB_LED_PINS=14,15,18,23,24,25,8,7,12,16,20,21

# Green slot LEDs 1-6
GREEN_LED_PINS=2,3,4,17,27,22

# Audio playback
# VLC is preferred for mp3/wav playback on Raspberry Pi
VLC_COMMAND=vlc
MACHINE_SOUND_DIR=/home/klongyaa4/Desktop/Capstone-Project/client/agent/sounds

# NFC simulation
# true = payment approved automatically after a short delay
# false = wait until simulate_nfc_tap() / real NFC signal is triggered
NFC_AUTO_APPROVE=true
NFC_SIMULATED_DELAY=0.75

# Socket.IO connection to the backend server
SERVER_SOCKET_URL=http://192.168.1.44:8000
SERVER_URL=http://192.168.1.44:8000

# If you need an explicit Chromium path, set it here
# CHROMIUM_COMMAND=/usr/bin/chromium-browser


#simple check hardware
#curl -X POST http://localhost:5000/jobs/start \
