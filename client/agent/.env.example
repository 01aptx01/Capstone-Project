# ==============================================================================
# Raspberry Pi — Hardware Agent (คัดลอกเป็น .env ข้าง agent.py)
# ==============================================================================
MACHINE_CODE=MP1-001
MACHINE_TOKEN=replace-with-secret-from-admin-dashboard
SERVER_SOCKET_URL=http://192.168.1.44:8000 # http://<host-LAN-IP>:8000
AGENT_DB_PATH=/data/agent.db
SENSOR_MODE=mock

MACHINE_UI_URL=http://192.168.1.44:3000 # http://<host-LAN-IP>:3000
GREEN_LED_PINS=2,3,4,17,27,22
RGB_LED_PINS=14,15,18,23,24,25,8,7,12,16,20,21
VLC_COMMAND=vlc
MACHINE_SOUND_DIR=./sounds

NFC_AUTO_APPROVE=false
NFC_SIMULATED_DELAY=0.75
NFC_SDA_PIN=11
NFC_SCK_PIN=5
NFC_MOSI_PIN=6
NFC_MISO_PIN=13
NFC_IRQ_PIN=19
NFC_RST_PIN=26

# Test: curl http://localhost:5000/health
# curl -X POST http://localhost:5000/jobs/start -H "Content-Type: application/json" \
#   -d '{"machine_code":"MP1-001","job_id":"test-1","items":[{"product_id":1,"quantity":1,"heating_time":15}]}'