sequenceDiagram
    autonumber
    actor User as ลูกค้า
    participant UI as machine-ui
    participant API as members_api Blueprint
    participant DB as MySQL users + orders

    rect rgb(245,245,255)
        Note over User,DB: GET /api/members/:phone (rate limit 10/min/IP)
        User->>UI: กรอกเบอร์ 10 หลัก
        UI->>API: GET /api/members/{phone}
        API->>DB: SELECT users WHERE phone_number
        DB-->>API: row | empty
        API-->>UI: found + points | 404
    end

    rect rgb(255,245,245)
        Note over User,DB: POST /api/members/earn (rate limit 20/min/IP)
        User->>UI: ยืนยันสะสมแต้ม
        UI->>API: POST phone, total_price, charge_id?
        API->>DB: INSERT or UPDATE users, points
        API->>DB: UPDATE orders SET user_id WHERE charge_id
        API-->>UI: ok + total_points
    end
