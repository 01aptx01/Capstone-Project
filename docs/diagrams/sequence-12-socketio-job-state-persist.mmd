sequenceDiagram
    autonumber
    participant Agent as Hardware Agent
    participant SIO as Socket.IO handler machine room
    participant DB as MySQL
    participant Ref as _auto_refund thread
    participant Dash as emit_dashboard_update

    Agent->>SIO: emit job.state / machine event payload
    SIO->>DB: INSERT machine_job_events
    alt event_type == job.state และ state terminal
        SIO->>DB: UPDATE orders SET status\n(DISPENSING|DONE|ERROR mapping)
    end
    SIO->>DB: UPDATE machines last_active
    SIO->>DB: commit
    alt state == ERROR และมี order_charge_id
        SIO--)Ref: start daemon thread
        Ref->>Ref: Omise create_refund
        Ref->>DB: UPDATE orders refunded
    end
    SIO->>Agent: broadcast job_event_broadcast (room machine)
    SIO->>Dash: dashboard_update (ADMIN_ROOM)
