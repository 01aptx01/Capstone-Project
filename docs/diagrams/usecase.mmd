%% Capstone-Project — Use case overview (machine-ui, admin-ui, server, agent, Omise)
%% Source: server/app/api/*, README, docker-compose

useCaseDiagram
    title Smart Vending — Use cases

    actor "ลูกค้า (ตู้)" as Customer
    actor "ผู้ดูแลระบบ" as Admin
    actor "Omise" as Omise
    actor "Hardware Agent\n(vending-pi)" as Agent

    package "Customer / machine-ui" {
        usecase "UC1: ดูสินค้าและสต็อก\nGET /api/products" as UC1
        usecase "UC2: ตรวจคูปอง\nPOST /api/buy/validate-coupon" as UC2
        usecase "UC3: สร้าง draft order\nPOST /api/buy/create-draft" as UC3
        usecase "UC4: Checkout ชำระเงิน\nPOST /api/buy/checkout" as UC4
        usecase "UC5: Poll สถานะชำระเงิน\nGET /api/buy/status/:charge_id" as UC5
        usecase "UC6: ยกเลิกออเดอร์ค้าง\nPOST /api/buy/cancel" as UC6
        usecase "UC7: Mock จ่าย (dev)\nPOST /api/buy/mock-pay" as UC7
        usecase "UC8: ค้นหาสมาชิก\nGET /api/members/:phone" as UC8
        usecase "UC9: สะสมแต้ม / ผูก order\nPOST /api/members/earn" as UC9
        usecase "UC24: Realtime job UI\nSocket.IO kiosk + job_event_broadcast" as UC24
    }

    package "Admin / admin-ui → /api/admin" {
        usecase "UC10: Dashboard summary\nGET /dashboard/summary" as UC10
        usecase "UC11: จัดการสินค้า\n/products CRUD" as UC11
        usecase "UC12: จัดการเครื่องและสล็อต\n/machines …" as UC12
        usecase "UC13: ลูกค้า (สมาชิก)\n/customers …" as UC13
        usecase "UC14: ออเดอร์\n/orders" as UC14
        usecase "UC15: คูปอง + redemptions\n/coupons …" as UC15
        usecase "UC16: Alerts\n/alerts …" as UC16
        usecase "UC17: รายงานยอด\n/reports/sales" as UC17
        usecase "UC18: Admin users (placeholder)\n/users" as UC18
    }

    package "Agent & telemetry" {
        usecase "UC19: Manual job test (dev)\nPOST /jobs/start on agent" as UC19
        usecase "UC20: Socket.IO job.start / machine_event" as UC20
    }

    package "System / internal" {
        usecase "UC22: Health check\nGET /api/health" as UC22
        usecase "UC23: Webhook Omise\nPOST /api/buy/omise-webhook" as UC23
    }

    Customer --> UC1
    Customer --> UC2
    Customer --> UC3
    Customer --> UC4
    Customer --> UC5
    Customer --> UC6
    Customer --> UC7
    Customer --> UC8
    Customer --> UC9
    Customer --> UC24

    Admin --> UC10
    Admin --> UC11
    Admin --> UC12
    Admin --> UC13
    Admin --> UC14
    Admin --> UC15
    Admin --> UC16
    Admin --> UC17
    Admin --> UC18

    Agent --> UC19
    Agent --> UC20

    UC4 ..> Omise : creates charge
    UC23 ..> Omise : charge.complete
    UC4 ..> UC20 : emit job.start after paid
    UC24 ..> UC20 : kiosk listens job_event_broadcast
    note right of UC4
        Checkout dispatches only via
        Socket.IO (no HTTP /dispense)
    end note
