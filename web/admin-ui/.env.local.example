# Copy to .env.local for local dev (Next.js loads this automatically).
# Use a port other than 3000 if machine-ui already uses 3000.

# Flask base URL (same host the browser can reach). Used by lib/admin-api.ts (fetch).
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8000

# Same base URL for Axios (lib/axios.ts). Prefer this name for new Phase 3 code; if unset, Axios falls back to NEXT_PUBLIC_ADMIN_API_URL.
NEXT_PUBLIC_API_URL=http://localhost:8000
